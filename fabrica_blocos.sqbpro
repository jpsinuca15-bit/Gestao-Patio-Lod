DROP TABLE IF EXISTS insumos;
DROP TABLE IF EXISTS estoque_blocos;

-- Cria a tabela de insumos com 'item' como chave única (evita duplicar)
CREATE TABLE insumos (
    item TEXT PRIMARY KEY,
    quantidade REAL DEFAULT 0,
    unidade_medida TEXT
);

-- Cria a tabela de blocos
CREATE TABLE estoque_blocos (
    tipo_bloco TEXT PRIMARY KEY,
    quantidade_total INTEGER DEFAULT 0
);

-- Insere os dados limpos uma única vez
INSERT INTO insumos VALUES ('Cimento', 0, 'Sacos'), ('Areia', 0, 'm³'), ('Brita 0', 0, 'm³'), ('Brita 1', 0, 'm³'), ('Pedrisco', 0, 'm³'), ('Pó de Pedra', 0, 'm³');
INSERT INTO estoque_blocos VALUES ('Bloco 10x20', 0), ('Bloco 15x20', 0), ('Canaleta', 0);</sql><current_tab id="0"/></tab_sql></sqlb_project>
